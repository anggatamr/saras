# SARAS Backend Environment Variables
PORT=8080
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GEMINI_API_KEY=your-google-gemini-api-key
BPS_API_KEY=your-bps-webapi-key

# Security Handshake Secret (Optional, used in GIN_MODE=release)
SARAS_API_SECRET=saras-secret-handshake-token-9988

# Monitoring (Optional)
SENTRY_DSN=
