# SARAS Frontend Environment Variables

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8080

# Secure Gateway Handshake Secret (matches SARAS_API_SECRET in backend)
NEXT_PUBLIC_API_SECRET=saras-secret-handshake-token-9988

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=super-secret-saras-key-12345

# Google OAuth Credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# Google Maps (NEXUS Map Embed)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# Monitoring (Optional)
NEXT_PUBLIC_SENTRY_DSN=
