rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Surveys (VERA Module)
    match /surveys/{surveyId} {
      allow read: if true; // Anyone can view active surveys
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.createdBy == request.auth.uid;
    }

    // Survey Responses
    match /surveys/{surveyId}/responses/{responseId} {
      allow create: if request.auth != null; // Authenticated users can submit responses
      allow read: if request.auth != null && get(/databases/$(database)/documents/surveys/$(surveyId)).data.createdBy == request.auth.uid; // Only creator can read
    }

    // Reports (ARIA/SIGMA)
    match /reports/{reportId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
  }
}
